// MNA Content — Phase 1 (PostgreSQL)
// Multi-tenant workspaces + RBAC + content metrics sync

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  SOSMED
  EDITOR
}

enum ContentStatus {
  IDEATION
  SCRIPTING
  EDITING
  READY_TO_REVIEW
  PUBLISHED
}

enum Platform {
  TIKTOK
  INSTAGRAM
  YOUTUBE
}

enum ScrapeJobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum KpiMetricType {
  CREATE_SCRIPTS
  FINISH_VIDEOS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts           Account[]
  sessions           Session[]
  userRoles          UserRole[]
  createdWorkspaces  Workspace[]       @relation("WorkspaceCreator")
  memberships        WorkspaceMember[]
  contentsCreated    Content[]         @relation("ContentCreator")
  contentsAssigned   Content[]         @relation("ContentAssignee")
  kpiTargets         KpiTarget[]
  scrapeJobs         ScrapeJob[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Lookup table for role catalog
model Role {
  id          String   @id @default(cuid())
  roleName    RoleName @unique @map("role_name")
  description String?

  userRoles         UserRole[]
  workspaceMembers  WorkspaceMember[]

  @@map("roles")
}

/// Optional platform-level role assignment
model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  brandCode   String?  @map("brand_code")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator     User              @relation("WorkspaceCreator", fields: [createdById], references: [id])
  members     WorkspaceMember[]
  contents    Content[]
  scrapeJobs  ScrapeJob[]
  kpiTargets  KpiTarget[]
  brands      BrandInventory[]
  linkTrackers LinkTracker[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  userId      String   @map("user_id")
  roleId      String   @map("role_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id])

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

/// Planner & tracker (Kanban + Monitor Data source)
model Content {
  id           String        @id @default(cuid())
  workspaceId  String        @map("workspace_id")
  title        String
  status       ContentStatus @default(IDEATION)
  caption      String?
  assetUrl     String?       @map("asset_url")
  publishedUrl String?       @map("published_url")
  uploadDate   DateTime?     @map("upload_date")
  lastSynced   DateTime?     @map("last_synced")
  createdById  String        @map("created_by")
  assignedToId String?       @map("assigned_to")
  position     Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  workspace  Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("ContentCreator", fields: [createdById], references: [id])
  assignedTo User?           @relation("ContentAssignee", fields: [assignedToId], references: [id])
  metrics    ContentMetric[]
  scrapeJobs ScrapeJob[]

  @@index([workspaceId, status])
  @@map("contents")
}

/// Per-platform public metrics (TikTok / Instagram / YouTube)
model ContentMetric {
  id        String   @id @default(cuid())
  contentId String   @map("content_id")
  platform  Platform
  views     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  syncedAt  DateTime @default(now()) @map("synced_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, platform])
  @@map("content_metrics")
}

model ScrapeJob {
  id          String          @id @default(cuid())
  url         String
  status      ScrapeJobStatus @default(QUEUED)
  attempts    Int             @default(0)
  error       String?
  workspaceId String          @map("workspace_id")
  contentId   String?         @map("content_id")
  createdById String?         @map("created_by")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content   Content?  @relation(fields: [contentId], references: [id], onDelete: SetNull)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([status, createdAt])
  @@map("scrape_jobs")
}

model KpiTarget {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  metricType  KpiMetricType @map("metric_type")
  targetValue Int           @map("target_value")
  month       Int
  year        Int

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, metricType, month, year])
  @@map("kpi_targets")
}

model BrandInventory {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("brand_inventory")
}

/// Outbound / bio link click tracker per workspace
model LinkTracker {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  label       String
  url         String
  clicks      Int       @default(0)
  lastClicked DateTime? @map("last_clicked")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("link_trackers")
}
