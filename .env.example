# PostgreSQL
# Local Docker: postgresql://mna:mna_dev_password@localhost:5432/mna_content?schema=public
# Vercel: use Neon / Vercel Postgres / Supabase connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Required for NextAuth (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Local: http://localhost:3000
# Vercel: https://YOUR-PROJECT.vercel.app  (or custom domain)
AUTH_URL="http://localhost:3000"

# Optional — leave empty to hide Google sign-in
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
